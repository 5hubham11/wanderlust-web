<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>

<body>
    <%layout(" /layouts/boilerplate")-%>
        <form class="needs-validation" method="post" action="/listings">
            <input name="listing[title]" type="text" placeholder="Title"><br> <br>
            <textarea name="listing[description]" placeholder="Description" cols="21" rows="2"></textarea><br><br>
            <input type="text" name="listing[image]" placeholder="Insert image URL"><br> <br>
            <input type="number" name="listing[price]" placeholder="Enter price"><br>
            <input type="text" name="listing[location]" placeholder="location"><br>
            <input type="text" name="listing[country]" placeholder="Country"><br>
            <br>
            <button>Add</button>
        </form>
</body>

</html>